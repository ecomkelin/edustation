# ===== 根 monorepo 公共环境变量示例 =====
# 复制为 .env (根) 或 packages/server/.env (后端) 自行填值

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/edustation

# 后端服务
PORT=8000
NODE_ENV=development

# JWT 密钥 (生产环境务必更换为长随机字符串)
JWT_ACCESS_SECRET=edustation-access-secret-change-me-in-production
JWT_REFRESH_SECRET=edustation-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Refresh Token Cookie
REFRESH_COOKIE_NAME=edustation_refresh_token

# CORS (dev 留空 = 允许所有 origin + credentials)
CORS_ORIGINS=

# 文件上传根目录 (server 端)
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads
