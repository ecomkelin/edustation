# ===== packages/server/.env (后端) =====
# 复制本文件为 .env 后填值

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/edustation

# Server
PORT=8000
NODE_ENV=development

# JWT (生产环境务必更换)
JWT_ACCESS_SECRET=edustation-access-secret-change-me-in-production
JWT_REFRESH_SECRET=edustation-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Refresh Token Cookie
REFRESH_COOKIE_NAME=edustation_refresh_token
# sameSite 策略：留空 dev=lax / prod=none(跨域必需)；同域反代部署的生产环境可显式设为 lax
# REFRESH_COOKIE_SAMESITE=lax
# secure 标志：留空 dev=false / prod=true；浏览器要求 sameSite=none 时 secure 必须为 true
# REFRESH_COOKIE_SECURE=true

# CORS (dev 留空 = 允许所有 origin；生产填入允许的来源逗号分隔)
CORS_ORIGINS=

# 文件上传
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads

# Seed 默认密码 (仅 seed 用)
SEED_DEFAULT_PASSWORD=Admin@123
