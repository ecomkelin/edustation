# ===== packages/server/.env (后端) =====
# 复制本文件为 .env 后填值

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/edustation_dev

# Server
PORT=3000
# development production test
NODE_ENV=development 

# JWT (生产环境务必更换)
JWT_ACCESS_SECRET=edustation-access-secret-change-me-in-production
JWT_REFRESH_SECRET=edustation-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=1200m
JWT_REFRESH_EXPIRES_IN=7d

# Refresh Token Cookie
REFRESH_COOKIE_NAME=edustation_refresh_token
# sameSite 策略：留空 dev=lax / prod=none(跨域必需)；同域反代部署的生产环境可显式设为 lax
# REFRESH_COOKIE_SAMESITE=lax
# secure 标志：留空 dev=false / prod=true；浏览器要求 sameSite=none 时 secure 必须为 true
# REFRESH_COOKIE_SECURE=true

# CORS (dev 留空 = 允许所有 origin；生产填入允许的来源逗号分隔)
CORS_ORIGINS=

# 文件上传
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads

# Seed 默认密码 (仅 seed 用)
SEED_DEFAULT_PASSWORD=Admin@123

# ===== AI 智能客服（阶段 3） =====
# 开关：true 才允许调用，否则 /agent/ping 返回 ok=false
AI_ENABLED=true
# 提供商标识（当前仅 MiniMax；预留扩展点）
AI_PROVIDER=MiniMax
# MiniMax 兼容 OpenAI chat completions 协议；按实际供应商控制台填写
MINIMAX_API_KEY=sk-cp-ahBwQw9S02yXdh8r64OInmyrohpp-u5G_MESSmGULWnJE7FYXvP6ylV6lpTnU54HaxsJlKPiWOFJJyAbhTI6LK0MFRhf3Tyg3W5A7gMOBDAbMfFvN24Ee2g
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
# 可选：默认 system prompt / 调参
# AI_SYSTEM_PROMPT=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_TIMEOUT_MS=60000
